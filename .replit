modules = ["nodejs-20", "bun-1.3"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[userenv]

[userenv.shared]
CONVEX_URL = "https://blessed-poodle-745.convex.cloud/"
NEXT_PUBLIC_CONVEX_URL = "https://blessed-poodle-745.convex.cloud/"
VITE_CONVEX_URL = "https://blessed-poodle-745.convex.cloud/"
CONVEX_DEPLOYMENT = "prod:blessed-poodle-745"
NODE_ENV = "development"
SITE_URL = "https://blessed-poodle-745.convex.cloud"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
